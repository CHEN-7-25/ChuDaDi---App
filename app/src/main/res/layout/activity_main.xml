<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<ScrollView
    android:id="@+id/setupPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="#1C2A24"
                android:textSize="28sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnNewGame"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_game" />

                <Button
                    android:id="@+id/btnResetMatch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/reset_match" />
            </LinearLayout>
        </LinearLayout>

        <RadioGroup
            android:id="@+id/rgRuleSet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbSouth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/south_rule" />

            <RadioButton
                android:id="@+id/rbNorth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/north_rule" />
        </RadioGroup>

        <TextView
            android:id="@+id/tvBluetoothTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/bluetooth_title"
            android:textColor="#1C2A24"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etBluetoothRoom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/bluetooth_room_hint"
            android:inputType="text"
            android:minHeight="48dp"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnBluetoothPermission"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="@string/bluetooth_permission" />

            <Button
                android:id="@+id/btnBluetoothDevices"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="@string/bluetooth_devices" />

            <Button
                android:id="@+id/btnBluetoothReady"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="@string/bluetooth_ready" />

            <Button
                android:id="@+id/btnBluetoothReconnect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/bluetooth_reconnect" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnBluetoothHost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="@string/bluetooth_host" />

            <Button
                android:id="@+id/btnBluetoothJoin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="@string/bluetooth_join" />

            <Button
                android:id="@+id/btnBluetoothDisconnect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/bluetooth_disconnect" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/pairedDeviceBoard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tvBluetoothStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#EAF0F7"
            android:minHeight="44dp"
            android:padding="10dp"
            android:text="@string/bluetooth_idle"
            android:textColor="#243142"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/roomStateBoard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#DCE9DF"
            android:padding="12dp"
            android:text="@string/game_waiting"
            android:textColor="#1C2A24"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvLastPlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFF8E5"
            android:padding="12dp"
            android:text="@string/no_last_play"
            android:textColor="#342818"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/playerBoard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tvHandTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/my_hand"
            android:textColor="#1C2A24"
            android:textSize="18sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/cardContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp"
                android:paddingTop="8dp" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvSelection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:padding="8dp"
            android:text="@string/no_selection"
            android:textColor="#46564E" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPlay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/play_cards" />

            <Button
                android:id="@+id/btnPass"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/pass" />

            <Button
                android:id="@+id/btnHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/hint" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="44dp"
            android:padding="10dp"
            android:text="@string/message_ready"
            android:textColor="#274237"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#FFFFFF"
            android:lineSpacingExtra="2dp"
            android:minHeight="120dp"
            android:padding="12dp"
            android:text="@string/log_empty"
            android:textColor="#2A332F"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>

    <FrameLayout
        android:id="@+id/roomPage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#7A3F25"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvTableStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#55301FCC"
            android:paddingStart="18dp"
            android:paddingTop="10dp"
            android:paddingEnd="18dp"
            android:paddingBottom="10dp"
            android:textColor="#F7D94B"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/tableSeatBoard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="46dp"
            android:layout_marginBottom="150dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <LinearLayout
                android:id="@+id/tableLeftSeats"
                android:layout_width="116dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTableLastPlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minHeight="64dp"
                    android:padding="10dp"
                    android:textColor="#FFF4D3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTableMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:minHeight="46dp"
                    android:padding="8dp"
                    android:textColor="#FFF8E1"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tableRightSeats"
                android:layout_width="116dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/tableHandScroll"
            android:layout_width="match_parent"
            android:layout_height="112dp"
            android:layout_gravity="bottom"
            android:layout_marginStart="176dp"
            android:layout_marginEnd="176dp"
            android:layout_marginBottom="38dp"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/tableCardContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/tableActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="112dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTablePass"
                android:layout_width="96dp"
                android:layout_height="48dp"
                android:text="@string/pass" />

            <Button
                android:id="@+id/btnTableHint"
                android:layout_width="96dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:text="@string/hint" />

            <Button
                android:id="@+id/btnTablePlay"
                android:layout_width="96dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:text="@string/play_cards" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTableNewGame"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="@string/new_game" />

            <Button
                android:id="@+id/btnTableLeaveRoom"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="@string/leave_room" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
