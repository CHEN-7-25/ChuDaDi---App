<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<ScrollView
    android:id="@+id/setupPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/lobby_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/casino_cream"
                android:textSize="28sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

	                <Button
	                    android:id="@+id/btnNewGame"
	                    android:layout_width="wrap_content"
	                    android:layout_height="wrap_content"
	                    android:background="@drawable/button_primary"
	                    android:drawableStart="@drawable/ic_restart_alt_24"
	                    android:drawablePadding="6dp"
	                    android:minHeight="44dp"
	                    android:paddingStart="14dp"
	                    android:paddingEnd="14dp"
	                    android:textColor="@color/ink_dark"
	                    android:text="@string/new_game" />

	                <Button
	                    android:id="@+id/btnResetMatch"
	                    android:layout_width="wrap_content"
	                    android:layout_height="wrap_content"
	                    android:layout_marginStart="8dp"
	                    android:background="@drawable/button_secondary"
	                    android:minHeight="44dp"
	                    android:paddingStart="14dp"
	                    android:paddingEnd="14dp"
	                    android:textColor="@color/casino_cream"
	                    android:text="@string/reset_match" />
            </LinearLayout>
        </LinearLayout>

        <RadioGroup
            android:id="@+id/rgRuleSet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

	            <RadioButton
	                android:id="@+id/rbSouth"
	                android:layout_width="wrap_content"
	                android:layout_height="wrap_content"
	                android:checked="true"
	                android:buttonTint="@color/casino_gold"
	                android:textColor="@color/casino_cream"
	                android:text="@string/south_rule" />

            <RadioButton
                android:id="@+id/rbNorth"
                android:layout_width="wrap_content"
	                android:layout_height="wrap_content"
	                android:layout_marginStart="16dp"
	                android:buttonTint="@color/casino_gold"
	                android:textColor="@color/casino_cream"
	                android:text="@string/north_rule" />
        </RadioGroup>

        <TextView
            android:id="@+id/tvBluetoothTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/bluetooth_title"
            android:textColor="@color/casino_cream"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etBluetoothRoom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/bluetooth_room_hint"
            android:inputType="text"
            android:minHeight="48dp"
            android:singleLine="true"
            android:textColor="@color/casino_cream"
            android:textColorHint="#BFD7C8"
            android:backgroundTint="@color/casino_gold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

	            <Button
	                android:id="@+id/btnBluetoothPermission"
	                android:layout_width="0dp"
	                android:layout_height="wrap_content"
	                android:layout_marginEnd="6dp"
	                android:layout_weight="1"
	                android:background="@drawable/button_secondary"
	                android:drawableStart="@drawable/ic_bluetooth_24"
	                android:drawablePadding="4dp"
	                android:minHeight="44dp"
	                android:textColor="@color/casino_cream"
	                android:text="@string/bluetooth_permission" />

            <Button
                android:id="@+id/btnBluetoothDevices"
                android:layout_width="0dp"
	                android:layout_height="wrap_content"
	                android:layout_marginEnd="6dp"
	                android:layout_weight="1"
	                android:background="@drawable/button_secondary"
	                android:minHeight="44dp"
	                android:textColor="@color/casino_cream"
	                android:text="@string/bluetooth_devices" />

            <Button
                android:id="@+id/btnBluetoothReady"
                android:layout_width="0dp"
	                android:layout_height="wrap_content"
	                android:layout_marginEnd="6dp"
	                android:layout_weight="1"
	                android:background="@drawable/button_primary"
	                android:minHeight="44dp"
	                android:textColor="@color/ink_dark"
	                android:text="@string/bluetooth_ready" />

            <Button
                android:id="@+id/btnBluetoothReconnect"
	                android:layout_width="0dp"
	                android:layout_height="wrap_content"
	                android:layout_weight="1"
	                android:background="@drawable/button_secondary"
	                android:minHeight="44dp"
	                android:textColor="@color/casino_cream"
	                android:text="@string/bluetooth_reconnect" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnBluetoothHost"
                android:layout_width="0dp"
	                android:layout_height="wrap_content"
	                android:layout_marginEnd="6dp"
	                android:layout_weight="1"
	                android:background="@drawable/button_primary"
	                android:minHeight="44dp"
	                android:textColor="@color/ink_dark"
	                android:text="@string/bluetooth_host" />

            <Button
                android:id="@+id/btnBluetoothJoin"
                android:layout_width="0dp"
	                android:layout_height="wrap_content"
	                android:layout_marginEnd="6dp"
	                android:layout_weight="1"
	                android:background="@drawable/button_secondary"
	                android:minHeight="44dp"
	                android:textColor="@color/casino_cream"
	                android:text="@string/bluetooth_join" />

            <Button
                android:id="@+id/btnBluetoothDisconnect"
	                android:layout_width="0dp"
	                android:layout_height="wrap_content"
	                android:layout_weight="1"
	                android:background="@drawable/button_danger"
	                android:minHeight="44dp"
	                android:textColor="@color/casino_cream"
	                android:text="@string/bluetooth_disconnect" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/pairedDeviceBoard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tvBluetoothStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/panel_dark"
            android:minHeight="44dp"
            android:padding="10dp"
            android:text="@string/bluetooth_idle"
            android:textColor="@color/casino_cream"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/roomStateBoard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/panel_dark"
            android:padding="12dp"
            android:text="@string/game_waiting"
            android:textColor="@color/casino_cream"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvLastPlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/panel_gold"
            android:padding="12dp"
            android:text="@string/no_last_play"
            android:textColor="@color/ink_dark"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/playerBoard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tvHandTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/my_hand"
            android:textColor="@color/casino_cream"
            android:textSize="18sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/cardContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp"
                android:paddingTop="8dp" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvSelection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/status_chip"
            android:minHeight="40dp"
            android:padding="8dp"
            android:text="@string/no_selection"
            android:textColor="@color/casino_cream" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

	            <Button
	                android:id="@+id/btnPlay"
	                android:layout_width="0dp"
	                android:layout_height="wrap_content"
	                android:layout_marginEnd="8dp"
	                android:layout_weight="1"
	                android:background="@drawable/button_primary"
	                android:drawableStart="@drawable/ic_play_arrow_24"
	                android:drawablePadding="6dp"
	                android:minHeight="46dp"
	                android:textColor="@color/ink_dark"
	                android:text="@string/play_cards" />

            <Button
                android:id="@+id/btnPass"
                android:layout_width="0dp"
	                android:layout_height="wrap_content"
	                android:layout_marginEnd="8dp"
	                android:layout_weight="1"
	                android:background="@drawable/button_secondary"
	                android:drawableStart="@drawable/ic_pass_24"
	                android:drawablePadding="6dp"
	                android:minHeight="46dp"
	                android:textColor="@color/casino_cream"
	                android:text="@string/pass" />

            <Button
	                android:id="@+id/btnHint"
	                android:layout_width="0dp"
	                android:layout_height="wrap_content"
	                android:layout_weight="1"
	                android:background="@drawable/button_primary"
	                android:drawableStart="@drawable/ic_lightbulb_24"
	                android:drawablePadding="6dp"
	                android:minHeight="46dp"
	                android:textColor="@color/ink_dark"
	                android:text="@string/hint" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/status_chip"
            android:minHeight="44dp"
            android:padding="10dp"
            android:text="@string/message_ready"
            android:textColor="@color/casino_cream"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/panel_dark"
            android:lineSpacingExtra="2dp"
            android:minHeight="120dp"
            android:padding="12dp"
            android:text="@string/log_empty"
            android:textColor="@color/casino_cream"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>

    <FrameLayout
        android:id="@+id/roomPage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/table_room_background"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvTableStatus"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="@drawable/table_top_bar"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="132dp"
            android:singleLine="true"
            android:textColor="#FFF7D94B"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/tableTopSeats"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="50dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="150dp"
            android:paddingEnd="150dp" />

        <LinearLayout
            android:id="@+id/tableLeftSeats"
            android:layout_width="132dp"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="22dp"
            android:layout_marginBottom="78dp"
            android:gravity="center"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/tableRightSeats"
            android:layout_width="132dp"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="22dp"
            android:layout_marginBottom="78dp"
            android:gravity="center"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/tableCenterPlayArea"
            android:layout_width="430dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="34dp"
            android:background="@drawable/table_center_panel"
            android:elevation="3dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tvTableLastPlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minHeight="28dp"
                android:textColor="#FFFFF2C4"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/tableLastPlayCards"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:clipToPadding="false"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingTop="6dp"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tvTableMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/status_chip"
                android:gravity="center"
                android:minHeight="38dp"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:textColor="@color/casino_cream"
                android:textSize="14sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/tableHandScroll"
            android:layout_width="match_parent"
            android:layout_height="132dp"
            android:layout_gravity="bottom"
            android:layout_marginStart="124dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/table_hand_tray"
            android:clipToPadding="false"
            android:fillViewport="false"
            android:paddingTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/tableCardContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/tableActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="142dp"
            android:gravity="center"
            android:orientation="horizontal">

	            <Button
	                android:id="@+id/btnTablePass"
	                android:layout_width="112dp"
	                android:layout_height="52dp"
	                android:background="@drawable/table_action_secondary"
	                android:backgroundTint="@null"
	                android:drawableStart="@drawable/ic_pass_24"
	                android:drawablePadding="4dp"
	                android:textColor="@color/casino_cream"
	                android:textSize="16sp"
	                android:textStyle="bold"
	                android:text="@string/pass" />

            <Button
                android:id="@+id/btnTableHint"
	                android:layout_width="112dp"
	                android:layout_height="52dp"
	                android:layout_marginStart="12dp"
	                android:background="@drawable/table_action_secondary"
	                android:backgroundTint="@null"
	                android:drawableStart="@drawable/ic_lightbulb_24"
	                android:drawablePadding="4dp"
	                android:textColor="@color/casino_cream"
	                android:textSize="16sp"
	                android:textStyle="bold"
	                android:text="@string/hint" />

            <Button
                android:id="@+id/btnTablePlay"
	                android:layout_width="128dp"
	                android:layout_height="52dp"
	                android:layout_marginStart="12dp"
	                android:background="@drawable/table_action_primary"
	                android:backgroundTint="@null"
	                android:drawableStart="@drawable/ic_play_arrow_24"
	                android:drawablePadding="4dp"
	                android:textColor="@color/ink_dark"
	                android:textSize="17sp"
	                android:textStyle="bold"
	                android:text="@string/play_cards" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tableLocalHud"
            android:layout_width="112dp"
            android:layout_height="118dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/table_hud_panel"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="12dp"
            android:orientation="horizontal">

	            <Button
	                android:id="@+id/btnTableNewGame"
	                android:layout_width="48dp"
	                android:layout_height="34dp"
	                android:background="@drawable/table_action_secondary"
	                android:backgroundTint="@null"
	                android:contentDescription="@string/new_game"
	                android:drawableStart="@drawable/ic_restart_alt_24"
	                android:minWidth="0dp"
	                android:minHeight="0dp"
	                android:paddingStart="12dp"
	                android:paddingEnd="12dp"
	                android:text="" />

            <Button
                android:id="@+id/btnTableLeaveRoom"
	                android:layout_width="48dp"
	                android:layout_height="34dp"
	                android:layout_marginStart="8dp"
	                android:background="@drawable/table_action_secondary"
	                android:backgroundTint="@null"
	                android:contentDescription="@string/leave_room"
	                android:drawableStart="@drawable/ic_logout_24"
	                android:minWidth="0dp"
	                android:minHeight="0dp"
	                android:paddingStart="12dp"
	                android:paddingEnd="12dp"
	                android:text="" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
