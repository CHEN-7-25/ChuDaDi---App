<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <solid android:color="#DCE7EAF1" />
            <stroke android:width="1dp" android:color="#A4AEB8" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <gradient android:angle="270" android:startColor="#FFFFFFFF" android:endColor="#FFE7EAF0" />
            <stroke android:width="1dp" android:color="#BFC8CEDA" />
        </shape>
    </item>
</selector>
