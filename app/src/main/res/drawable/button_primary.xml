<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#665B5144" />
            <stroke android:width="1dp" android:color="#55756859" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#D69E35" />
            <stroke android:width="1dp" android:color="#FFF3C071" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="@color/casino_gold" />
            <stroke android:width="1dp" android:color="#FFF7D489" />
        </shape>
    </item>
</selector>
