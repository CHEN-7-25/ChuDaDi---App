<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#5541544B" />
            <stroke android:width="1dp" android:color="#4D7C8C7F" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#335E4C" />
            <stroke android:width="1dp" android:color="#B8E7C888" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#D91B332B" />
            <stroke android:width="1dp" android:color="#668CBBA2" />
        </shape>
    </item>
</selector>
